# Anthropic
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# LINE Messaging API
LINE_CHANNEL_ACCESS_TOKEN=your_line_channel_access_token_here
LINE_CHANNEL_SECRET=your_line_channel_secret_here

# Database
DATABASE_URL=sqlite:///./uranai.db

# Threads (Meta Developer Console で取得)
# 取得方法: https://developers.facebook.com → アプリ作成 → Threads API 有効化
THREADS_ACCESS_TOKEN=your_threads_long_lived_access_token_here
THREADS_USER_ID=your_threads_numeric_user_id_here

# 管理エンドポイント認証 (POST /admin/generate-code, /admin/upgrade-user)
ADMIN_SECRET_KEY=your_strong_secret_key_here

# アップグレードコードのプレフィックス
UPGRADE_CODE_PREFIX=SION

# App
APP_ENV=development
PORT=8000
