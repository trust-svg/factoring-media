# LINE Messaging API
LINE_CHANNEL_TOKEN=your_line_channel_access_token

# Rakuten API (https://webservice.rakuten.co.jp/)
RAKUTEN_APP_ID=your_rakuten_app_id

# Yahoo API (https://e.developer.yahoo.co.jp/)
YAHOO_APP_ID=your_yahoo_app_id

# Check interval in minutes (default: 3)
CHECK_INTERVAL_MINUTES=3

# Server port
PORT=8001
